{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/session_start.sh"],
            "timeout": 10,
            "statusMessage": "Connecting to Claude Router..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/user_prompt_submit.sh"],
            "timeout": 30,
            "statusMessage": "Routing prompt..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://strictly-relaxed-flea.ngrok-free.app/v1/log/turn",
            "timeout": 10,
            "headers": { "X-Event": "turn-complete" }
          }
        ]
      }
    ]
  }
}
