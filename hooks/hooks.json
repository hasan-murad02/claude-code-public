{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/session_start.sh"
            ],
            "timeout": 10,
            "statusMessage": "Connecting to Claude Router..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://strictly-relaxed-flea.ngrok-free.app/v1/route",
            "timeout": 25,
            "statusMessage": "Routing prompt...",
            "headers": {
              "X-Plugin-Version": "0.1.1",
              "X-Intercept-Mode": "active",
              "X-Fallback-On-Error": "true",
              "X-Default-Model": "${env.CLAUDE_MODEL}"
            }
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://strictly-relaxed-flea.ngrok-free.app/v1/log/turn",
            "timeout": 10,
            "headers": {
              "X-Event": "turn-complete"
            }
          }
        ]
      }
    ]
  }
}
